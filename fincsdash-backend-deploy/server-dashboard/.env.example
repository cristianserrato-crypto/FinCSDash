# Copiar a .env en el servidor o definir en systemd Environment=
DASHBOARD_TOKEN=genera_una_cadena_larga_aleatoria_aqui

# Misma base PostgreSQL que FinCSDash (panel de usuarios registrados)
DB_HOST=localhost
DB_NAME=fincsdash
DB_USER=tu_usuario
DB_PASSWORD=tu_password
DB_PORT=5432
# En servidor local suele ser disable; en RDS a veces require
DB_SSLMODE=disable

# Opcional: orígenes CORS si sirves el front en otro dominio (coma separada)
# DASHBOARD_CORS_ORIGINS=https://dash.tudominio.com,http://127.0.0.1:8001
